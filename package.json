{
  "name": "getgiffgaff-seo-edge-gateway",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:content": "node scripts/build-growth-pages.mjs && node scripts/build-source-cards.mjs",
    "build": "npm run build:content && node scripts/build-release-artifact.mjs",
    "test": "node --test test/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test test/*.test.mjs",
    "verify": "npm test && npm run validate:research && npm run build && node scripts/verify-release-artifact.mjs",
    "verify:browser": "node scripts/browser-verify.mjs",
    "verify:preview": "node scripts/verify-preview-release.mjs",
    "verify:seo": "node scripts/verify-seo-release.mjs",
    "validate:outreach": "node scripts/validate-outreach-assets.mjs",
    "validate:research": "node scripts/validate-research-ledger.mjs",
    "cloudflare:rules:generate": "node scripts/cloudflare-redirect-rules.mjs generate",
    "cloudflare:rules:validate": "node scripts/cloudflare-redirect-rules.mjs validate",
    "validate:commerce-evidence": "node scripts/validate-commerce-evidence.mjs",
    "growth:ops": "node scripts/growth-ops.mjs",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "submit:indexnow:all": "node scripts/submit-indexnow.mjs --all",
    "gate:maintenance": "node scripts/verify-maintenance-release.mjs --mode maintenance",
    "gate:commerce": "node scripts/verify-maintenance-release.mjs --mode commerce",
    "deploy": "node scripts/deploy-release.mjs --mode commerce",
    "deploy:maintenance": "node scripts/deploy-release.mjs --mode maintenance",
    "deploy:preview": "node scripts/deploy-preview-release.mjs"
  },
  "devDependencies": {
    "playwright": "1.61.1",
    "pngjs": "7.0.0",
    "wrangler": "4.112.0"
  }
}
