{
  "name": "getgiffgaff-seo-edge-gateway",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test test/*.test.mjs",
    "verify": "npm test && node scripts/verify-contact-hotfix.mjs",
    "verify:seo": "node scripts/verify-seo-release.mjs",
    "predeploy": "npm run verify",
    "deploy": "wrangler pages deploy public --project-name getgiffgaff --branch main --commit-dirty=true",
    "postdeploy": "npm run verify:seo -- --base-url https://getgiffgaff.com --expected-url-count 34"
  }
}
